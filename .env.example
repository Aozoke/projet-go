# Intervalle entre deux flush du buffer vers l'AOF.
WASMREDIS_FLUSH_INTERVAL_MS=1000

# Intervalle entre deux snapshots complets du state.
WASMREDIS_SNAPSHOT_INTERVAL_MS=120000

# TTL par defaut en secondes. 0 signifie pas d'expiration par defaut.
WASMREDIS_DEFAULT_TTL_SECONDS=0

# Frequence du balayage actif des cles expirees.
WASMREDIS_EXPIRATION_SWEEP_INTERVAL_MS=1000

# Ordre du futur B-Tree utilise pour les requetes de range.
WASMREDIS_BTREE_ORDER=32

# Nombre de lignes gardees en marge autour de la zone visible dans l'UI.
WASMREDIS_VIRTUAL_SCROLL_OVERSCAN=10

# Taille maximale cible du buffer avant flush force.
WASMREDIS_MAX_BUFFER_SIZE=10000
